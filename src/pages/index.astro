---
import { getAllLessons } from "../lib/lessons";
import type { LessonListItem } from "../lib/lessons";
import "../styles/global.css";

const lessons = getAllLessons();

function formatLessonDate(lesson: LessonListItem): string | undefined {
  return formatDate(lesson.updatedAt) ?? formatDate(lesson.createdAt);
}

function formatDate(value: string | undefined): string | undefined {
  if (!value) {
    return undefined;
  }

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return new Intl.DateTimeFormat("en", {
    dateStyle: "medium"
  }).format(date);
}

function buildCardFootnote(lesson: LessonListItem): string | undefined {
  const parts = [lesson.sourceType, formatLessonDate(lesson)].filter(
    (part): part is string => Boolean(part)
  );

  return parts.length > 0 ? parts.join(" · ") : undefined;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Simple lessons, written for easy understanding."
    />
    <title>Your learning shelf</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="intro" aria-labelledby="page-title">
        <h1 id="page-title">Your learning shelf</h1>
        <p class="intro-tagline">
          Simple lessons, written for easy understanding.
        </p>
        <p class="library-count">{lessons.length} lessons</p>
      </section>

      <section class="library" aria-labelledby="library-title">
        <h2 id="library-title" class="sr-only">Library</h2>

        {
          lessons.length > 0 ? (
            <ol class="lesson-list" aria-label="Prepared lessons">
              {lessons.map((lesson) => {
                const footnote = buildCardFootnote(lesson);

                return (
                  <li class="lesson-card">
                    <a class="lesson-card-link" href={`${import.meta.env.BASE_URL}lessons/${lesson.slug}/`}>
                      <div class="lesson-card-header">
                        <div class="lesson-card-titleblock">
                          <h3>{lesson.title}</h3>
                          <p class="lesson-big-idea">{lesson.bigIdea}</p>
                        </div>
                        {lesson.status === "draft" && (
                          <span class="draft-badge">Draft</span>
                        )}
                      </div>

                      {lesson.description && (
                        <p class="lesson-description">{lesson.description}</p>
                      )}

                      {footnote && (
                        <p class="lesson-card-footnote">{footnote}</p>
                      )}
                    </a>
                  </li>
                );
              })}
            </ol>
          ) : (
            <div class="empty-state">
              <h3>Nothing to read yet.</h3>
              <p>
                Add a Markdown lesson to <code>content/lessons/</code> and it
                will show up here.
              </p>
            </div>
          )
        }
      </section>
    </main>
  </body>
</html>
