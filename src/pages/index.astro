---
import { getAllLessons } from "../lib/lessons";
import type { LessonListItem } from "../lib/lessons";
import "../styles/global.css";

const lessons = getAllLessons();

function formatLessonDate(lesson: LessonListItem): string | undefined {
  return formatDate(lesson.updatedAt) ?? formatDate(lesson.createdAt);
}

function formatDate(value: string | undefined): string | undefined {
  if (!value) {
    return undefined;
  }

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return new Intl.DateTimeFormat("en", {
    dateStyle: "medium"
  }).format(date);
}

function buildCardFootnote(lesson: LessonListItem): string | undefined {
  const parts = [lesson.sourceType, formatLessonDate(lesson)].filter(
    (part): part is string => Boolean(part)
  );

  return parts.length > 0 ? parts.join(" · ") : undefined;
}

const readyCount = lessons.filter((lesson) => lesson.status === "ready").length;
const draftCount = lessons.length - readyCount;
const lessonCountLabel = `${lessons.length} ${lessons.length === 1 ? "lesson" : "lessons"}`;

function formatSourceCount(lesson: LessonListItem): string {
  const count = lesson.sourceRef.length;
  return `${count} ${count === 1 ? "source" : "sources"}`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A calm personal learning shelf for simple, easy-to-understand lessons."
    />
    <title>Your learning shelf</title>
  </head>
  <body class="home-page">
    <main class="app-shell">
      <header class="site-header" aria-label="Reader">
        <a class="brand-mark" href={import.meta.env.BASE_URL}>
          Personal Learning Reader
        </a>
        <p>{readyCount} ready / {draftCount} draft</p>
      </header>

      <section class="home-hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="kicker">Personal learning reader</p>
          <h1 id="page-title">A quiet shelf for clear lessons.</h1>
          <p class="hero-tagline">
            Prepared lessons from your own materials, rewritten in simple
            English and kept ready for slow, focused reading.
          </p>
        </div>

        <p class="library-count" aria-label="Library summary">
          <strong>{lessonCountLabel}</strong>
          <span>prepared for calm reading</span>
        </p>
      </section>

      <section class="library-section" aria-labelledby="library-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Library</p>
            <h2 id="library-title">Choose a lesson</h2>
          </div>
          <p>Each card opens a prepared reading page. The source stays in the background.</p>
        </div>

        {
          lessons.length > 0 ? (
            <ol class="lesson-grid" aria-label="Prepared lessons">
              {lessons.map((lesson, index) => {
                const footnote = buildCardFootnote(lesson);

                return (
                  <li class="lesson-card">
                    <a class="lesson-card-link" href={`${import.meta.env.BASE_URL}lessons/${lesson.slug}/`}>
                      <div class="lesson-card-topline">
                        <span class="lesson-number" aria-hidden="true">
                          {String(index + 1).padStart(2, "0")}
                        </span>
                        <span class={`status-badge status-${lesson.status}`}>
                          {lesson.status}
                        </span>
                      </div>

                      <div class="lesson-card-content">
                        <h3>{lesson.title}</h3>
                        <p class="lesson-big-idea">{lesson.bigIdea}</p>
                        {lesson.description && (
                          <p class="lesson-description">{lesson.description}</p>
                        )}
                      </div>

                      <div class="lesson-card-footer">
                        <span>{footnote ?? "Prepared lesson"}</span>
                        <span>{formatSourceCount(lesson)}</span>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ol>
          ) : (
            <div class="empty-state">
              <h3>Nothing to read yet.</h3>
              <p>
                Add a Markdown lesson to <code>content/lessons/</code> and it
                will appear here as a calm reading card.
              </p>
            </div>
          )
        }
      </section>
    </main>
  </body>
</html>
