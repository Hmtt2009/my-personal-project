---
import {
  getAllLessonDetails,
  getLessonBySlug
} from "../../lib/lessons";
import "../../styles/global.css";

export function getStaticPaths() {
  return getAllLessonDetails().map((lesson) => ({
    params: { slug: lesson.slug }
  }));
}

const { slug } = Astro.params;
const lesson = slug ? getLessonBySlug(slug) : undefined;

if (!lesson) {
  throw new Error(`Lesson not found: ${slug}`);
}

const Content = lesson.Content;

function formatLessonDate(value: string | undefined): string | undefined {
  if (!value) {
    return undefined;
  }

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return new Intl.DateTimeFormat("en", {
    dateStyle: "medium"
  }).format(date);
}

const metadata: Array<[string, string | undefined]> = [
  ["Source", lesson.sourceType],
  ["Status", lesson.status],
  ["Created", formatLessonDate(lesson.createdAt)],
  ["Updated", formatLessonDate(lesson.updatedAt)]
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={lesson.description ?? lesson.bigIdea}
    />
    <title>{lesson.title}</title>
  </head>
  <body>
    <main class="page-shell lesson-page">
      <a class="back-link" href={import.meta.env.BASE_URL}>Back to library</a>

      <article>
        <header class="lesson-header">
          <p class="eyebrow">Prepared lesson</p>
          <h1>{lesson.title}</h1>
          <p class="lesson-big-idea">{lesson.bigIdea}</p>
          {lesson.description && (
            <p class="lesson-description">{lesson.description}</p>
          )}

          <dl class="lesson-meta lesson-meta-large">
            {
              metadata.map(([label, value]) =>
                value ? (
                  <div>
                    <dt>{label}</dt>
                    <dd>{value}</dd>
                  </div>
                ) : null
              )
            }
          </dl>
        </header>

        <section class="lesson-body" aria-label="Simplified lesson">
          <Content />
        </section>

        <section class="source-reference" aria-labelledby="source-reference-title">
          <h2 id="source-reference-title">Source reference</h2>
          <p>
            Source material is kept as reference only. The simplified lesson is
            the main reading content.
          </p>
          <ul>
            {lesson.sourceRef.map((source) => <li>{source}</li>)}
          </ul>
        </section>
      </article>
    </main>
  </body>
</html>
