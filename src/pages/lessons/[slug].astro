---
import {
  getAllLessonDetails,
  getLessonBySlug
} from "../../lib/lessons";
import "../../styles/global.css";

export function getStaticPaths() {
  return getAllLessonDetails().map((lesson) => ({
    params: { slug: lesson.slug }
  }));
}

const { slug } = Astro.params;
const lesson = slug ? getLessonBySlug(slug) : undefined;

if (!lesson) {
  throw new Error(`Lesson not found: ${slug}`);
}

const Content = lesson.Content;

function formatLessonDate(value: string | undefined): string | undefined {
  if (!value) {
    return undefined;
  }

  const date = new Date(value);

  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return new Intl.DateTimeFormat("en", {
    dateStyle: "medium"
  }).format(date);
}

function buildMetaLine(): string | undefined {
  const parts: string[] = [];

  if (lesson.sourceType) {
    parts.push(lesson.sourceType);
  }

  const updated = formatLessonDate(lesson.updatedAt);
  const created = formatLessonDate(lesson.createdAt);

  if (updated) {
    parts.push(`Updated ${updated}`);
  } else if (created) {
    parts.push(`Created ${created}`);
  }

  return parts.length > 0 ? parts.join(" · ") : undefined;
}

function isExternalUrl(value: string): boolean {
  return value.startsWith("http://") || value.startsWith("https://");
}

function formatSourceLabel(source: string, index: number): string {
  const fallback = `Source ${index + 1}`;

  if (isExternalUrl(source)) {
    try {
      const url = new URL(source);
      const host = url.hostname.replace(/^www\./, "");
      return `${fallback}: ${host}`;
    } catch {
      return fallback;
    }
  }

  const trimmed = source.replace(/\/$/, "");
  const filename = trimmed.split("/").at(-1);

  return filename ? `${fallback}: ${filename}` : fallback;
}

const metaLine = buildMetaLine();
const sourceCountLabel = `${lesson.sourceRef.length} ${lesson.sourceRef.length === 1 ? "source" : "sources"}`;
const tocItems = lesson.headings.filter((heading) => heading.depth === 2);
const showToc = tocItems.length >= 2;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={lesson.description ?? lesson.bigIdea}
    />
    <title>{lesson.title}</title>
  </head>
  <body class="reading-page">
    <main class="reading-shell">
      <nav class="reading-nav" aria-label="Lesson navigation">
        <a class="back-link" href={import.meta.env.BASE_URL}>Back to library</a>
        <span class={`status-badge status-${lesson.status}`}>
          {lesson.status}
        </span>
      </nav>

      <article class="reading-article">
        <header class="reading-hero">
          <p class="kicker">Prepared lesson</p>
          <h1>{lesson.title}</h1>
          <p class="lesson-big-idea">{lesson.bigIdea}</p>
          {lesson.description && (
            <p class="lesson-description">{lesson.description}</p>
          )}
          <div class="lesson-meta-row" aria-label="Lesson metadata">
            {metaLine && <span>{metaLine}</span>}
            <span>{sourceCountLabel}</span>
          </div>
        </header>

        {
          showToc && (
            <nav class="lesson-sections" aria-label="Lesson sections">
              <p class="section-kicker">Sections</p>
              <ol>
                {tocItems.map((heading) => (
                  <li>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          )
        }

        <section class="lesson-body" aria-label="Simplified lesson">
          <Content />
        </section>

        <section class="source-reference" aria-labelledby="source-reference-title">
          <div>
            <p class="section-kicker">Reference</p>
            <h2 id="source-reference-title">Source material</h2>
          </div>
          <p>This lesson was prepared from the references below. The full source stays outside the main reading flow.</p>
          <ul>
            {lesson.sourceRef.map((source, index) =>
              isExternalUrl(source) ? (
                <li>
                  <a
                    href={source}
                    rel="noreferrer"
                    title={source}
                    aria-label={`Open source reference: ${source}`}
                  >
                    {formatSourceLabel(source, index)}
                  </a>
                </li>
              ) : (
                <li>
                  <code title={source}>{formatSourceLabel(source, index)}</code>
                </li>
              )
            )}
          </ul>
        </section>
      </article>
    </main>
  </body>
</html>
